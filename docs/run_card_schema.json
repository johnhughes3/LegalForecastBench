{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://legalforecast.local/schemas/run_card.schema.json",
  "title": "LegalForecast-MTD Run Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run",
    "model",
    "sampling",
    "policy",
    "pricing",
    "hashes",
    "accounting_summary",
    "notes"
  ],
  "properties": {
    "schema_version": {
      "const": "legalforecast.run_card.v1"
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "cycle_id",
        "run_type",
        "generated_at",
        "evaluation_timestamp",
        "harness_version",
        "run_label",
        "limitations"
      ],
      "properties": {
        "run_id": { "$ref": "#/$defs/non_empty_string" },
        "cycle_id": { "$ref": "#/$defs/non_empty_string" },
        "run_type": {
          "type": "string",
          "enum": ["official", "rapid", "pilot", "descriptive", "annual_aggregate"]
        },
        "generated_at": { "$ref": "#/$defs/iso_datetime" },
        "evaluation_timestamp": { "$ref": "#/$defs/iso_datetime" },
        "harness_version": { "$ref": "#/$defs/non_empty_string" },
        "run_label": { "$ref": "#/$defs/non_empty_string" },
        "limitations": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model_id",
        "display_name",
        "model_version_or_snapshot",
        "release_timestamp",
        "provider_training_cutoff_status",
        "provider_training_cutoff",
        "network_disabled",
        "search_disabled",
        "tool_policy",
        "context_limit",
        "known_cutoff_publicity_caveats"
      ],
      "properties": {
        "provider": { "$ref": "#/$defs/non_empty_string" },
        "model_id": { "$ref": "#/$defs/non_empty_string" },
        "display_name": { "$ref": "#/$defs/non_empty_string" },
        "model_version_or_snapshot": { "$ref": "#/$defs/non_empty_string" },
        "release_timestamp": {
          "anyOf": [{ "$ref": "#/$defs/iso_datetime" }, { "type": "null" }]
        },
        "provider_training_cutoff_status": {
          "type": "string",
          "enum": ["known", "unknown", "not_disclosed"]
        },
        "provider_training_cutoff": {
          "anyOf": [{ "$ref": "#/$defs/iso_date" }, { "type": "null" }]
        },
        "network_disabled": { "const": true },
        "search_disabled": { "const": true },
        "tool_policy": {
          "type": "string",
          "enum": ["no_tools", "controlled_docket_tool_only"]
        },
        "context_limit": {
          "type": "integer",
          "minimum": 1
        },
        "known_cutoff_publicity_caveats": {
          "type": "array",
          "items": { "$ref": "#/$defs/non_empty_string" }
        }
      }
    },
    "sampling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["temperature", "top_p", "max_output_tokens"],
      "properties": {
        "temperature": { "$ref": "#/$defs/non_negative_number" },
        "top_p": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "max_output_tokens": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "network_disabled",
        "search_disabled",
        "tool_policy",
        "tool_call_cap"
      ],
      "properties": {
        "network_disabled": { "const": true },
        "search_disabled": { "const": true },
        "tool_policy": {
          "type": "string",
          "enum": ["no_tools", "controlled_docket_tool_only"]
        },
        "tool_call_cap": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "pricing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pricing_source",
        "input_token_price",
        "output_token_price",
        "price_unit"
      ],
      "properties": {
        "pricing_source": { "$ref": "#/$defs/non_empty_string" },
        "input_token_price": { "$ref": "#/$defs/non_negative_number" },
        "output_token_price": { "$ref": "#/$defs/non_negative_number" },
        "price_unit": {
          "const": "usd_per_1m_tokens"
        }
      }
    },
    "hashes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prompt_sha256",
        "scorer_sha256",
        "model_registry_sha256",
        "manifest_sha256",
        "prediction_unit_sha256",
        "label_sha256"
      ],
      "properties": {
        "prompt_sha256": { "$ref": "#/$defs/prefixed_sha256" },
        "scorer_sha256": { "$ref": "#/$defs/prefixed_sha256" },
        "model_registry_sha256": { "$ref": "#/$defs/prefixed_sha256" },
        "manifest_sha256": { "$ref": "#/$defs/prefixed_sha256" },
        "prediction_unit_sha256": { "$ref": "#/$defs/prefixed_sha256" },
        "label_sha256": { "$ref": "#/$defs/prefixed_sha256" }
      }
    },
    "accounting_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_count",
        "prediction_unit_count",
        "request_count",
        "prompt_tokens",
        "completion_tokens",
        "total_tokens",
        "mean_tool_calls_per_case",
        "median_tool_calls_per_case",
        "p95_tool_calls_per_case",
        "cost_per_case",
        "cost_per_prediction_unit",
        "mean_latency_ms",
        "p95_latency_ms",
        "invalid_output_rate",
        "refusal_rate",
        "content_filter_rate"
      ],
      "properties": {
        "case_count": { "$ref": "#/$defs/positive_integer" },
        "prediction_unit_count": { "$ref": "#/$defs/positive_integer" },
        "request_count": { "$ref": "#/$defs/non_negative_integer" },
        "prompt_tokens": { "$ref": "#/$defs/non_negative_integer" },
        "completion_tokens": { "$ref": "#/$defs/non_negative_integer" },
        "total_tokens": { "$ref": "#/$defs/non_negative_integer" },
        "mean_tool_calls_per_case": { "$ref": "#/$defs/non_negative_number" },
        "median_tool_calls_per_case": { "$ref": "#/$defs/non_negative_number" },
        "p95_tool_calls_per_case": { "$ref": "#/$defs/non_negative_number" },
        "cost_per_case": { "$ref": "#/$defs/non_negative_number" },
        "cost_per_prediction_unit": { "$ref": "#/$defs/non_negative_number" },
        "mean_latency_ms": { "$ref": "#/$defs/non_negative_number" },
        "p95_latency_ms": { "$ref": "#/$defs/non_negative_number" },
        "invalid_output_rate": { "$ref": "#/$defs/rate" },
        "refusal_rate": { "$ref": "#/$defs/rate" },
        "content_filter_rate": { "$ref": "#/$defs/rate" }
      }
    },
    "notes": {
      "type": "array",
      "items": { "$ref": "#/$defs/non_empty_string" }
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "iso_datetime": {
      "type": "string",
      "format": "date-time"
    },
    "iso_date": {
      "type": "string",
      "format": "date"
    },
    "prefixed_sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "positive_integer": {
      "type": "integer",
      "minimum": 1
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "non_negative_number": {
      "type": "number",
      "minimum": 0
    },
    "rate": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
